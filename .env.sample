# 預設的 System Prompt (用於引導 AI 的回答風格或規則)
# 若留空則不使用自定義 Prompt
DEFAULT_SYSTEM_PROMPT=您是一位專業的研究助手，請根據提供的參考資料精確回答問題。如果資料中沒有提到，請誠實告知。

# 預設的模型 ID 設定
# 您可以透過 `python3 notebook_cli.py list --model` 指令查詢系統中所有可用的模型 ID

# 用於問答與對話的語言模型
DEFAULT_CHAT_MODEL_ID=

# 用於知識庫向量化的嵌入模型
DEFAULT_EMBEDDING_MODEL_ID=

# 用於文字轉語音的模型
DEFAULT_TTS_MODEL_ID=

# 用於語音轉文字的模型
DEFAULT_STT_MODEL_ID=
